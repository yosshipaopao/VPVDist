{
  "name": "vpvdist",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "generate": "drizzle-kit generate:sqlite --schema=src/lib/server/schema.ts",
    "ups": "drizzle-kit up:sqlite --schema=src/lib/server/schema.ts"
  },
  "devDependencies": {
    "@skeletonlabs/skeleton": "^1.9.0",
    "@sveltejs/adapter-auto": "^2.1.0",
    "@sveltejs/adapter-cloudflare-workers": "^1.1.3",
    "@sveltejs/kit": "^1.22.3",
    "autoprefixer": "^10.4.14",
    "postcss": "^8.4.26",
    "postcss-load-config": "^4.0.1",
    "svelte": "^4.0.5",
    "svelte-check": "^3.4.6",
    "tailwindcss": "^3.3.3",
    "tslib": "^2.6.0",
    "typescript": "^5.1.6",
    "vite": "^4.4.4"
  },
  "type": "module",
  "dependencies": {
    "@auth/core": "^0.9.0",
    "@auth/sveltekit": "^0.3.5",
    "@floating-ui/dom": "^1.4.5",
    "@iconify/svelte": "^3.1.4",
    "@sveltejs/adapter-cloudflare": "^2.3.1",
    "drizzle-kit": "^0.19.5",
    "drizzle-orm": "^0.27.2"
  }
}
